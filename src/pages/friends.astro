---
import { getEntry } from "astro:content";
import Comment from "@components/comment/index.astro";
import FriendCard from "@components/features/FriendCard.astro";
import FriendRulesModal from "@components/features/FriendRulesModal.astro";
import { Icon } from "astro-icon/components";
import {
	commentConfig,
	friendsPageConfig,
	getEnabledFriends,
	siteConfig,
} from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

if (!siteConfig.pages.friends) {
	return Astro.redirect("/404/");
}

const friendsPost = await getEntry("spec", "friends");
if (!friendsPost) {
	throw new Error("friends page content not found");
}

const isCommentEnabled =
	commentConfig?.type &&
	commentConfig.type !== "none" &&
	friendsPageConfig.showComment !== false;

const items = getEnabledFriends();
const allTags = [...new Set(items.flatMap((item) => item.tags || []))].sort();

const title = friendsPageConfig.title || i18n(I18nKey.friends);
const description =
	friendsPageConfig.description || i18n(I18nKey.friendsDescription);
---

<MainGridLayout title={title} description={description}>
	<div
		class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32"
	>
		<div class="card-base z-10 px-9 py-6 relative w-full">
			<div class="mb-4">
				<div class="flex items-center justify-between gap-3 mb-3">
					<div class="flex items-center gap-3">
						<div
							class="h-8 w-8 rounded-lg bg-(--primary) flex items-center justify-center text-white dark:text-black/70"
						>
							<Icon name="material-symbols:group" class="text-[1.5rem]" />
						</div>
						<div
							class="text-3xl font-bold text-neutral-900 dark:text-neutral-100"
						>
							{title}
						</div>
					</div>
					{
						friendsPageConfig.applyLink && (
							<button
								type="button"
								data-open-friend-rules
								class="shrink-0 px-3.5 py-2 rounded-xl border border-(--line-divider) hover:border-(--primary) hover:bg-(--card-bg) text-sm font-medium text-neutral-700 dark:text-neutral-200 transition-colors duration-200 cursor-pointer flex items-center gap-1.5"
							>
								<Icon
									name="material-symbols:help-outline"
									class="text-base text-(--primary)"
								/>
								如何申请友链
							</button>
						)
					}
				</div>
				{
					description && (
						<p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed mb-5">
							{description}
						</p>
					)
				}
			</div>

			{
				items.length > 0 && (
					<div class="mb-5">
						<div class="relative mb-3">
							<Icon
								name="material-symbols:search"
								class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-400 dark:text-neutral-500 text-lg pointer-events-none"
							/>
							<input
								type="text"
								data-search
								placeholder={i18n(I18nKey.searchFriends) || "搜索友链..."}
								class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-(--line-divider) bg-transparent text-neutral-900 dark:text-neutral-100 placeholder-neutral-400 dark:placeholder-neutral-500 focus:border-(--primary) focus:ring-1 focus:ring-(--primary) outline-none transition-all duration-200 text-sm"
							/>
						</div>
						<div class="flex flex-wrap gap-2">
							<button
								type="button"
								data-tag="all"
								class="friend-tag-btn px-3 py-1.5 rounded-lg bg-(--primary) text-white transition-colors duration-200 text-sm font-medium cursor-pointer"
							>
								{i18n(I18nKey.all)}
							</button>
							{allTags.map((tag) => (
								<button
									type="button"
									data-tag={tag}
									class="friend-tag-btn px-3 py-1.5 rounded-lg bg-(--btn-regular-bg) text-(--btn-content) hover:bg-(--btn-regular-bg-hover) transition-colors duration-200 text-sm font-medium cursor-pointer"
								>
									{tag}
								</button>
							))}
						</div>
					</div>
				)
			}

			<div class="friends-grid my-4">
				{
					items.length === 0 && (
						<div class="col-span-full flex flex-col items-center justify-center py-12 text-neutral-400 dark:text-neutral-500">
							<Icon
								name="material-symbols:group-off-outline"
								class="text-4xl mb-3"
							/>
							<div class="text-sm">{i18n(I18nKey.friendsEmpty)}</div>
						</div>
					)
				}
				{items.map((item) => (
					<FriendCard
						title={item.title}
						href={item.siteurl}
						imgurl={item.imgurl}
						desc={item.desc}
						tags={item.tags}
					/>
				))}
			</div>

			<div class="friends-empty hidden flex-col items-center justify-center py-12 text-neutral-400 dark:text-neutral-500">
				<Icon name="material-symbols:search-off-rounded" class="text-4xl mb-3" />
				<div class="text-sm">{i18n(I18nKey.searchNoResults)}</div>
			</div>
		</div>
	</div>

	{isCommentEnabled && (
		<div class="mt-4">
			<Comment post={friendsPost} customPath="/friends/" />
		</div>
	)}

	<FriendRulesModal applyLink={friendsPageConfig.applyLink} />

	<script is:inline>
		(function() {
			if (window.__friendFilterReady) return;
			window.__friendFilterReady = true;

			function applyFilters() {
				const grid = document.querySelector(".friends-grid");
				if (!grid) return;
				const cards = Array.from(grid.querySelectorAll(".friend-card"));
				const searchInput = document.querySelector("[data-search]");
				const emptyHint = document.querySelector(".friends-empty");
				const keyword = ((searchInput && searchInput.value) || "")
					.trim()
					.toLowerCase();
				const activeTagBtn = document.querySelector(".friend-tag-btn.bg-\\(--primary\\)");
				const activeTag = activeTagBtn ? activeTagBtn.dataset.tag : "all";

				let visibleCount = 0;
				cards.forEach(function(card) {
					const tags = ((card.dataset.tags || "").split(",")).filter(Boolean);
					const title = (card.dataset.title || "").toLowerCase();
					const matchTag = activeTag === "all" || tags.includes(activeTag);
					const matchKeyword =
						!keyword || title.includes(keyword);
					const show = matchTag && matchKeyword;
					card.style.display = show ? "" : "none";
					if (show) visibleCount++;
				});

				if (emptyHint) {
					if (visibleCount === 0 && (keyword || activeTag !== "all")) {
						emptyHint.classList.remove("hidden");
						emptyHint.classList.add("flex");
					} else {
						emptyHint.classList.add("hidden");
						emptyHint.classList.remove("flex");
					}
				}
			}

			document.addEventListener("click", function(e) {
				var btn = e.target.closest(".friend-tag-btn");
				if (!btn) return;
				var buttons = document.querySelectorAll(".friend-tag-btn");
				buttons.forEach(function(b) {
					b.classList.remove("bg-(--primary)", "text-white");
					b.classList.add(
						"bg-(--btn-regular-bg)",
						"text-(--btn-content)",
						"hover:bg-(--btn-regular-bg-hover)",
					);
				});
				btn.classList.remove(
					"bg-(--btn-regular-bg)",
					"text-(--btn-content)",
					"hover:bg-(--btn-regular-bg-hover)",
				);
				btn.classList.add("bg-(--primary)", "text-white");
				applyFilters();
			});

			document.addEventListener("input", function(e) {
				if (e.target && e.target.matches("[data-search]")) {
					applyFilters();
				}
			});

			applyFilters();
			document.addEventListener("astro:page-load", applyFilters);
		})();
	</script>

	<style is:global>
		.friends-grid {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
			gap: 0.75rem;
		}
	</style>
</MainGridLayout>
